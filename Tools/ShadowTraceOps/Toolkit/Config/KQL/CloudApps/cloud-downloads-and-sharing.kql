// Shadow Trace Ops - Cloud app data movement review
let TargetUser = "{TargetUser}";
CloudAppEvents
| where Timestamp > ago({LookbackDays}d)
| where AccountUpn =~ TargetUser or AccountDisplayName has split(TargetUser, "@")[0]
| where ActionType has_any ("Download", "FileDownloaded", "Share", "AnonymousLinkCreated", "Upload")
| project Timestamp, AccountUpn, AccountDisplayName, Application, ActionType, IPAddress, ObjectName, RawEventData
| order by Timestamp desc
